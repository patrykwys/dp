 
    @Test
    void shouldReturnTrueWhenDeletedAndFalseWhenNotFound() throws IOException {
        DeleteResponse deleted = mock(DeleteResponse.class);
        when(deleted.result()).thenReturn(Result.Deleted);
 
        DeleteResponse notFound = mock(DeleteResponse.class);
        when(notFound.result()).thenReturn(Result.NotFound);
 
        when(elasticSearchClient.delete(any(Function.class)))
            .thenReturn(deleted, notFound);
 
        assertTrue(elasticSearchService.deleteReportFromElasticSearch("1"));
        assertFalse(elasticSearchService.deleteReportFromElasticSearch("999"));
    }
 
