            () -> elasticSearchService.deleteReportFromElasticSearch("1")
        );
        assertTrue(exception.getMessage().contains("1"));
    }
 
    // ── bulkDeleteFromElasticSearch ──
 
    @Test
    void shouldBulkDeleteAndHandlePartialFailures() throws IOException {
        BulkResponseItem successItem = mock(BulkResponseItem.class);
        when(successItem.error()).thenReturn(null);
 
        ErrorCause errorCause = mock(ErrorCause.class);
        when(errorCause.reason()).thenReturn("document missing");
        BulkResponseItem failedItem = mock(BulkResponseItem.class);
        when(failedItem.error()).thenReturn(errorCause);
        when(failedItem.id()).thenReturn("2");
 
        BulkResponse bulkResponse = mock(BulkResponse.class);
        when(bulkResponse.errors()).thenReturn(true);
        when(bulkResponse.items()).thenReturn(List.of(successItem, failedItem));
        when(elasticSearchClient.bulk(any(BulkRequest.class))).thenReturn(bulkResponse);
 
        // Empty list skips ES entirely
        elasticSearchService.bulkDeleteFromElasticSearch(List.of());
        verify(elasticSearchClient, never()).bulk(any(BulkRequest.class));
 
        // Partial failures are logged but don't throw
        assertDoesNotThrow(
            () -> elasticSearchService.bulkDeleteFromElasticSearch(List.of("1", "2"))
        );
    }
 
