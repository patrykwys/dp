    }
 
    // ── getAllReportIdsFromElasticSearch ──
 
    @Test
    void shouldCollectIdsAcrossScrollPages() throws IOException {
        Hit<Void> hit1 = mock(Hit.class);
        when(hit1.id()).thenReturn("1");
        Hit<Void> hit2 = mock(Hit.class);
        when(hit2.id()).thenReturn("2");
        Hit<Void> hit3 = mock(Hit.class);
        when(hit3.id()).thenReturn("3");
 
        HitsMetadata<Void> initialHits = mock(HitsMetadata.class);
        when(initialHits.hits()).thenReturn(List.of(hit1, hit2));
        SearchResponse<Void> searchResponse = mock(SearchResponse.class);
        when(searchResponse.hits()).thenReturn(initialHits);
        when(searchResponse.scrollId()).thenReturn("scroll_1");
        when(elasticSearchClient.search(any(Function.class), eq(Void.class)))
            .thenReturn(searchResponse);
 
        HitsMetadata<Void> scrollHits = mock(HitsMetadata.class);
        when(scrollHits.hits()).thenReturn(List.of(hit3));
        ScrollResponse<Void> scrollResponse1 = mock(ScrollResponse.class);
        when(scrollResponse1.hits()).thenReturn(scrollHits);
        when(scrollResponse1.scrollId()).thenReturn("scroll_2");
 
        HitsMetadata<Void> emptyHits = mock(HitsMetadata.class);
        when(emptyHits.hits()).thenReturn(List.of());
        ScrollResponse<Void> scrollResponse2 = mock(ScrollResponse.class);
        when(scrollResponse2.hits()).thenReturn(emptyHits);
        when(scrollResponse2.scrollId()).thenReturn("scroll_3");
 
        when(elasticSearchClient.scroll(any(Function.class), eq(Void.class)))
            .thenReturn(scrollResponse1, scrollResponse2);
 
        List<String> result = elasticSearchService.getAllReportIdsFromElasticSearch();
 
        assertEquals(List.of("1", "2", "3"), result);
        verify(elasticSearchClient).clearScroll(any(Function.class));
    }
 
    @Test
    void shouldClearScrollContextEvenOnFailure() throws IOException {
        HitsMetadata<Void> initialHits = mock(HitsMetadata.class);
        when(initialHits.hits()).thenReturn(List.of());
        SearchResponse<Void> searchResponse = mock(SearchResponse.class);
        when(searchResponse.hits()).thenReturn(initialHits);
        when(searchResponse.scrollId()).thenReturn("scroll_1");
        when(elasticSearchClient.search(any(Function.class), eq(Void.class)))
            .thenReturn(searchResponse);
 
        when(elasticSearchClient.scroll(any(Function.class), eq(Void.class)))
            .thenThrow(new IOException("scroll failed"));
 
        assertThrows(
            UncheckedIOException.class,
            () -> elasticSearchService.getAllReportIdsFromElasticSearch()
        );
 
        verify(elasticSearchClient).clearScroll(any(Function.class));
    }
